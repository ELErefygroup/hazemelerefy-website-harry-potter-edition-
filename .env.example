# Copy this file to `.env.local` and fill in real values for local dev.
# In production, set the same keys in your Vercel project Settings → Environment Variables.

# ─── Web3Forms (service-request form on /services) ─────────────────────
# Free tier: 3000 submissions/month, no signup payment required.
# Get a key at https://web3forms.com — register the form's domain (the bare
# host, e.g. `hazemelerefey.vercel.app`, NOT including the path).
NEXT_PUBLIC_WEB3FORMS_KEY=
